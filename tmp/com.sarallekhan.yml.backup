Categories:
  - Writing
License: MIT
AuthorName: NxAdx
WebSite: https://github.com/NxAdx/saral-lekhan-pro
SourceCode: https://github.com/NxAdx/saral-lekhan-pro
IssueTracker: https://github.com/NxAdx/saral-lekhan-pro/issues

RepoType: git
Repo: https://github.com/NxAdx/saral-lekhan-pro.git

Builds:
  - versionName: '2.17.33'
    versionCode: 100
    commit: v2.17.33
    subdir: android/app
    sudo:
      - apt-get update
      - apt-get install -y npm
    init:
      - cd ../..
      - npm install --legacy-peer-deps
    gradle:
      - release
    prebuild:
      - cd ../..
      - npx expo prebuild --platform android --clean
    scandelete:
      - node_modules

  - versionName: '2.17.56'
    versionCode: 102
    commit: v2.17.56
    subdir: android/app
    sudo:
      - apt-get update
      - apt-get install -y npm openjdk-17-jdk-headless
    init:
      - cd ../..
      - npm install --legacy-peer-deps
    gradle:
      - yes
    prebuild:
      - cd ../..
      - sed -i -e '1a "expo":{"autolinking":{"android":{"buildFromSource":[".*"]}}},' package.json
      - export SARAL_BUILD_TARGET=fdroid && npx expo prebuild -p android --clean
      - sed -i 's/System.getenv("SARAL_BUILD_TARGET") ?: "direct"/"fdroid"/' android/app/build.gradle
      - sed -i -e '/signingConfig /d' android/app/build.gradle
    scandelete:
      - node_modules

AutoUpdateMode: Version
UpdateCheckMode: Tags
CurrentVersion: '2.17.56'
CurrentVersionCode: 102